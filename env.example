# ============================================================
# JarviisAI — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=jarviis
POSTGRES_PASSWORD=jarviis_secret
POSTGRES_DB=jarviisdb

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── Auth Service ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_min32chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SECRET_KEY=CHANGE_ME_min32chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI Providers ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...       # Required for AI test generation
OPENAI_API_KEY=sk-...             # Optional fallback model

# ── GitHub Integration ────────────────────────────────────────
GITHUB_CLIENT_ID=                  # OAuth App: github.com/settings/developers
GITHUB_CLIENT_SECRET=              # OAuth App secret
GITHUB_WEBHOOK_SECRET=change_me_webhook_secret
GITHUB_APP_ID=                     # GitHub App (Phase 2)
GITHUB_APP_PRIVATE_KEY=            # GitHub App private key (PEM, base64)

# ── Email (optional — for account verification) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@jarviis.ai

# ── Internal security ─────────────────────────────────────────
INTERNAL_SERVICE_SECRET=jarviis-internal-secret-change-me

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:8005

# ── Stripe (Phase 5 billing) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
