# ═══════════════════════════════════════════════════════════════════
# JarviisAI — Environment Configuration
# Copy this file to .env and fill in all values marked REQUIRED.
# Values with defaults are optional for local development.
# ═══════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=jarviis
POSTGRES_PASSWORD=jarviis_secret           # CHANGE IN PRODUCTION
POSTGRES_DB=jarviisdb
REDIS_PASSWORD=redis_secret               # CHANGE IN PRODUCTION

# ── Auth (REQUIRED) ──────────────────────────────────────────
JWT_SECRET=                               # REQUIRED: min 32 chars, use: openssl rand -hex 32
SECRET_KEY=                               # REQUIRED: min 32 chars, use: openssl rand -hex 32

# ── AI (REQUIRED for test generation) ────────────────────────
ANTHROPIC_API_KEY=                        # REQUIRED: sk-ant-... from console.anthropic.com

# ── Billing (REQUIRED for paid plans) ────────────────────────
STRIPE_SECRET_KEY=                        # REQUIRED: sk_live_... or sk_test_... from Stripe
STRIPE_WEBHOOK_SECRET=                    # REQUIRED: whsec_... from Stripe webhook settings
STRIPE_PUBLISHABLE_KEY=                   # REQUIRED: pk_live_... or pk_test_...
STRIPE_PRO_MONTHLY=                       # Stripe Price ID for Pro monthly
STRIPE_PRO_YEARLY=                        # Stripe Price ID for Pro yearly
STRIPE_TEAM_MONTHLY=                      # Stripe Price ID for Team monthly
STRIPE_TEAM_YEARLY=                       # Stripe Price ID for Team yearly
STRIPE_ENTERPRISE_MONTHLY=               # Stripe Price ID for Enterprise monthly

# ── Email / SMTP ──────────────────────────────────────────────
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=                               # Your SMTP username
SMTP_PASSWORD=                           # Your SMTP password
EMAIL_FROM=noreply@jarviis.ai

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8005
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=      # Same as STRIPE_PUBLISHABLE_KEY

# ── GitHub OAuth (for GitHub sign-in) ─────────────────────────
GITHUB_CLIENT_ID=                         # From GitHub OAuth App settings
GITHUB_CLIENT_SECRET=                     # From GitHub OAuth App settings

# ── GitHub App (for CI/CD integration) ────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=                   # Multi-line PEM — wrap in quotes
GITHUB_WEBHOOK_SECRET=

# ── Security ──────────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=jarviis-internal-secret  # CHANGE IN PRODUCTION

# ── Observability ─────────────────────────────────────────────
ENVIRONMENT=development                   # development | staging | production
LOG_LEVEL=info                            # debug | info | warning | error

# ── Service URLs (auto-resolved in Docker, override for local dev) ──
AUTH_SERVICE_URL=http://auth-service:8001
PROJECTS_SERVICE_URL=http://projects:8002
CRAWLER_SERVICE_URL=http://crawler:8003
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8004
TEST_EXECUTOR_URL=http://test-executor:8005
HEALING_SERVICE_URL=http://healing:8006
VISUAL_SERVICE_URL=http://visual:8007
DEPLOY_SERVICE_URL=http://deploy:8008
EVENTS_SERVICE_URL=http://events:8017
USAGE_SERVICE_URL=http://usage:8018
NOTIFICATIONS_SERVICE_URL=http://notifications:8019
ANALYTICS_SERVICE_URL=http://analytics:8020
REPORTS_SERVICE_URL=http://reports:8021
FLAGS_SERVICE_URL=http://feature-flags:8022
AUDIT_SERVICE_URL=http://audit:8023
SEARCH_SERVICE_URL=http://search:8024
COMPLIANCE_SERVICE_URL=http://compliance:8025
HEALTH_SERVICE_URL=http://health-scoring:8026
